{
  "name": "stoa-desktop",
  "version": "1.0.0",
  "description": "Stoa Desktop Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.stoa.desktop",
    "productName": "Stoa",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/stoa-icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/stoa-icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/stoa-icon.png"
    }
  }
}
